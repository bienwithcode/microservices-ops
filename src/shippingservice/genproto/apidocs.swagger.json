  "definitions": {
    "hipstershopAd": {
      "type": "object",
      "properties": {
        "redirectUrl": {
          "type": "string",
          "description": "url to redirect to when an ad is clicked."
        },
        "text": {
          "type": "string",
          "description": "short advertisement text to display."
        }
      }
    },
    "hipstershopAdResponse": {
      "type": "object",
      "properties": {
        "ads": {
          "type": "array",
