        },
        "creditCardCvv": {
          "type": "integer",
          "format": "int32"
        },
        "creditCardExpirationYear": {
          "type": "integer",
          "format": "int32"
        },
        "creditCardExpirationMonth": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "hipstershopCurrencyConversionRequest": {
      "type": "object",
      "properties": {
        "from": {
          "$ref": "#/definitions/hipstershopMoney"
        },
        "toCode": {
          "type": "string",
          "description": "The 3-letter currency code defined in ISO 4217."
        }
      }
    },
    "hipstershopEmpty": {
      "type": "object"
    },
    "hipstershopGetQuoteRequest": {
      "type": "object",
      "properties": {
